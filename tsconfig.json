{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "ES2020"],
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmitOnError": true,

    "outDir": "dist",
    "rootDir": "src",

    "types": ["chrome"],
    "skipLibCheck": true
  },
  "include": ["src"]
}
