{
  "name": "YouTube Watch Time Tracker",
  "description": "Tracks actual YouTube watch time.",
  "version": "0.1.0",
  "manifest_version": 3,

  "permissions": [
    "storage",
    "tabs",
    "scripting"
    ],
  "host_permissions": ["https://www.youtube.com/*"],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
      "default_icon": {
      "48": "icons/youtube48.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}

